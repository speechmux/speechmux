# Copy to .env and edit before running docker compose.
# Usage: docker compose --profile sherpa up

# ── Port bindings (host side) ────────────────────────────────────────────────
GRPC_PORT=50051
HTTP_PORT=8090
WS_PORT=8091
API_PORT=8000
WEB_PORT=3020

# ── STT model directory ──────────────────────────────────────────────────────
# Directory containing sherpa-onnx model files (mounted read-only at /models).
# Expected layout:
#   plugin-stt-sherpa-onnx/models/
#     ko-streaming/encoder-epoch-99-avg-1.int8.onnx
#     ko-streaming/decoder-epoch-99-avg-1.int8.onnx
#     ko-streaming/joiner-epoch-99-avg-1.int8.onnx
#     ko-streaming/tokens.txt
MODELS_DIR=./plugin-stt-sherpa-onnx/models

# ── Auth ─────────────────────────────────────────────────────────────────────
# Leave CORE_API_KEY empty to disable Core auth.
CORE_API_KEY=
# Leave ACCESS_TOKEN empty to allow all browser clients without a token.
ACCESS_TOKEN=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Origins allowed to connect to the web API. Separate multiple with commas.
CORS_ORIGINS=*    # restrict to specific origins in production (e.g. https://myapp.ts.net:8444)
